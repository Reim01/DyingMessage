<Window x:Class="Agent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agent"
        mc:Ignorable="d"
        Title="MainWindow" Height="620" Width="360">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 1. 헤더 (최소화된 타이틀 & 액션 버튼) -->
            <RowDefinition Height="Auto"/>
            <!-- 2. AI 시스템 진단 (메인 영역 - 가장 큼) -->
            <RowDefinition Height="*"/>
            <!-- 3. 현재 자원 상태 (오밀조밀한 압축형) -->
            <RowDefinition Height="Auto"/>
            <!-- 4. Top 3 프로세스 (오밀조밀한 압축형) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= 1. HEADER ================= -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="CrashGuard" FontSize="16" FontWeight="Bold" Foreground="#111111"/>
            </StackPanel>

            <!-- 작은 상단 버튼들 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="📄 리포트" FontSize="11" Padding="8,4" Margin="0,0,4,0"
                        Background="#FFFFFF" BorderBrush="#DDDDDD" Foreground="#333333" Cursor="Hand"/>
                <Button Content="⚙️" FontSize="11" Padding="6,4"
                        Background="#FFFFFF" BorderBrush="#DDDDDD" Foreground="#333333" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- ================= 2. AI 진단 영역 (메인 / 가장 큼) ================= -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="AI 시스템 진단" FontSize="13" FontWeight="Bold" Foreground="#666666" Margin="0,0,0,8"/>

                <!-- 상태 뱃지 -->
                <Border Grid.Row="1" Background="#E6F4EA" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🛡️" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="시스템 정상 동작 중" FontWeight="Bold" FontSize="12" Foreground="#137333"/>
                    </StackPanel>
                </Border>

                <!-- AI 진단 상세 설명 (스크롤 지원) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="#444444">
                        최근 비정상적인 셧다운 기록이 없습니다.
                        <LineBreak/><LineBreak/>
                        현재 하드웨어 점유율은 안정권이며, 강종 유발 위험 패턴이 감지되지 않았습니다.
                        <LineBreak/><LineBreak/>
                        시스템이 강제로 꺼질 경우, 재부팅 시 분석된 마지막 30초 간의 원인 리포트가 이곳에 기록됩니다.
                    </TextBlock>
                </ScrollViewer>

                <TextBlock Grid.Row="3" Text="마지막 분석: 방금 전" FontSize="10" Foreground="#AAA" HorizontalAlignment="Right" Margin="0,6,0,0"/>
            </Grid>
        </Border>

        <!-- ================= 3. 자원 상태 (오밀조밀 압축형) ================= -->
        <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,10"
                BorderBrush="#E5E5E5" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="실시간 자원" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="0,0,0,8"/>

                <!-- CPU -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CPU" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1" Value="32" Height="6" Background="#F0F0F0" Foreground="#0078D4" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="32%" FontSize="11" HorizontalAlignment="Right" Foreground="#555" VerticalAlignment="Center"/>
                </Grid>

                <!-- RAM -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="RAM" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1" Value="68" Height="6" Background="#F0F0F0" Foreground="#0078D4" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="68%" FontSize="11" HorizontalAlignment="Right" Foreground="#555" VerticalAlignment="Center"/>
                </Grid>

                <!-- GPU -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="GPU" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1" Value="15" Height="6" Background="#F0F0F0" Foreground="#0078D4" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="15%" FontSize="11" HorizontalAlignment="Right" Foreground="#555" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================= 4. Top 3 프로세스 (오밀조밀 압축형) ================= -->
        <Border Grid.Row="3" Background="#FFFFFF" CornerRadius="8" Padding="12"
                BorderBrush="#E5E5E5" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="자원 점유 Top 3" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="0,0,0,6"/>

                <!-- Item 1 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="chrome.exe" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" Text="14.2%" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                    <TextBlock Grid.Column="2" Text="2,450MB" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                </Grid>

                <!-- Item 2 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="UnrealEditor.exe" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" Text="11.8%" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                    <TextBlock Grid.Column="2" Text="4,120MB" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                </Grid>

                <!-- Item 3 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="devenv.exe" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" Text="4.5%" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                    <TextBlock Grid.Column="2" Text="1,850MB" FontSize="11" HorizontalAlignment="Right" Foreground="#666"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
